
# .env est ignore par git donc mon PIN et mes tokens ne seront jamais commites

# ── option 1 (moins securise) : PIN en clair dans le bundle
VITE_CODE_PIN=123456

# ── option 2 (recommande) : hash SHA-256 du PIN — le plaintext n'est plus dans le bundle
# pour generer sous Windows :
#   node -e "const c=require('crypto');console.log(c.createHash('sha256').update('VOTRE_PIN').digest('hex'))"
# si les deux sont definis, VITE_CODE_PIN_HASH est prioritaire
VITE_CODE_PIN_HASH=

# token du bot telegram via @BotFather
VITE_TELEGRAM_TOKEN=token_tel

# chat ID telegram — envoie un msg a @userinfobot pour l'obtenir
VITE_TELEGRAM_CHAT_ID=chat_id
